NODE_ENV=production
PORT=3000
API_PREFIX=api/v1

# Credenciales Postgres (docker-compose.server.yml + restore)
POSTGRES_USER=condominium
POSTGRES_PASSWORD=condominium_secret
POSTGRES_DB=condominium_platform

# En Docker el compose fuerza REDIS_HOST=redis.
# DATABASE_URL DEBE usar host "postgres" (nombre del servicio), no localhost.
DATABASE_URL=postgresql://condominium:condominium_secret@postgres:5432/condominium_platform?schema=public

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-prod
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-prod
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

REDIS_HOST=redis
REDIS_PORT=6379

# Origen del front (IP pública o dominio). Con nginx same-origin suele bastar *
CORS_ORIGIN=*
APP_URL=http://TU_IP_PUBLICA

UPLOAD_MAX_SIZE=10485760
STORAGE_PATH=./uploads

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Condominium Platform <noreply@tu-dominio.com>"

MOROSITY_CRON_ENABLED=true
MOROSITY_CRON_SCHEDULE=0 8 * * *

SWAGGER_ENABLED=false
