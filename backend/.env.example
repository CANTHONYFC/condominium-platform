NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

DATABASE_URL=postgresql://condominium:condominium_secret@localhost:5433/condominium_platform?schema=public

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

REDIS_HOST=localhost
REDIS_PORT=6379

CORS_ORIGIN=http://localhost:4200

UPLOAD_MAX_SIZE=10485760
STORAGE_PATH=./uploads

# SMTP (estados de cuenta / morosidad)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="Condominium Platform <noreply@condominium.local>"
APP_URL=http://localhost:4200

# Cron diario morosidad (estados de cuenta por email)
MOROSITY_CRON_ENABLED=true
MOROSITY_CRON_SCHEDULE=0 8 * * *

SWAGGER_ENABLED=true
